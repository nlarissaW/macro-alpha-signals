import pandas as pd
import yfinance as yf
from pandas_datareader import data as web

# ================================
# 1. Download Data
# ================================

# SP500
sp500 = yf.download("^GSPC", start="2010-01-01")
sp500["returns"] = sp500["Adj Close"].pct_change()

# VIX
vix = yf.download("^VIX", start="2010-01-01")

# Unemployment (FRED)
unrate = web.DataReader("UNRATE", "fred", "2010-01-01")

# ================================
# 2. Merge Data
# ================================

df = sp500[["returns"]].join(
    vix[["Close"]].rename(columns={"Close": "vix"})
)

df = df.join(unrate)
df = df.dropna()

df.head()
